# ============================================================
# xhs-game-agent .env template
# 复制为 .env 后填入真实凭证。.env 不进 git。
# 注意：值后面不能加注释（pydantic-settings 不支持行内注释）
# ============================================================

# ---- LLM (V0 必需) ----
ANTHROPIC_API_KEY=sk-ant-...

# ---- Telegram (V0 必需) ----
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_CHAT_ID=123456789

# ---- IsThereAnyDeal (S8 折扣值不值，可选) ----
# 从 https://isthereanydeal.com/dev/app/ 的 API Keys 获取
ITAD_API_KEY=

# ---- Reddit (V1 启用 trend 后必需) ----
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=xhs_game_agent/0.1 by /u/your_username

# ---- fal.ai (V1 启用图片生成后必需) ----
FAL_API_KEY=

# ---- 运行时配置 ----
ENV=local
DATABASE_URL=sqlite:///./xhs_agent.db
LOG_LEVEL=INFO
DAILY_BUDGET_USD=2.0

# ---- Pipeline 调度（每天 9:30 / 17:30 UTC 各跑一次）----
TREND_PIPELINE_HOUR=9
CONTENT_PIPELINE_HOURS=9,17

# ---- Telegram 行为 ----
# true=正常推送，false=关掉推送（开发时用）
TELEGRAM_PUSH_ENABLED=true
# true=只 log 不发，false=正常发送
TELEGRAM_DRY_RUN=false
