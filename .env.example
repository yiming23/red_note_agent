# ============================================================
# xhs-game-agent .env template
# 复制为 .env 后填入真实凭证。.env 不进 git。
# ============================================================

# ---- LLM (V0 必需) ----
ANTHROPIC_API_KEY=sk-ant-...

# ---- Telegram (V0 必需) ----
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_CHAT_ID=123456789

# ---- IsThereAnyDeal (S8 折扣值不值，可选) ----
ITAD_API_KEY=                      # 从 https://isthereanydeal.com/dev/app/ 的 API Keys 获取

# ---- Reddit (V1 启用 trend 后必需) ----
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=xhs_game_agent/0.1 by /u/your_username

# ---- fal.ai (V1 启用图片生成后必需) ----
FAL_API_KEY=

# ---- 运行时配置 ----
ENV=local                          # local / production
DATABASE_URL=sqlite:///./xhs_agent.db
LOG_LEVEL=INFO
DAILY_BUDGET_USD=2.0

# ---- Pipeline 调度 ----
TREND_PIPELINE_HOUR=9              # 每天 9:00 跑 trend pipeline
CONTENT_PIPELINE_HOURS=9,17        # 每天 9:30 / 17:30 跑 content pipeline
                                   # (实际触发时间会在指定 hour 后偏移 30 分钟，避开 trend)

# ---- Telegram 行为 ----
TELEGRAM_PUSH_ENABLED=true         # 关掉可避免开发时疯狂推送
TELEGRAM_DRY_RUN=false             # true: 只 log 不发
